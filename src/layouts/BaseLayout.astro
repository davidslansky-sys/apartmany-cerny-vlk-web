---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Apartmány Černý vlk | Borová Lada',
  description = 'Ubytování v Borových Ladech na Šumavě.',
} = Astro.props;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="format-detection" content="telephone=no" />
  </head>

  <body>
    <a class="skip-link" href="#obsah">Přeskočit na obsah</a>
    <slot />
  </body>
</html>
