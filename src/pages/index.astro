---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Apartmány Černý vlk | Borová Lada"
  description="Ubytování v Borových Ladech na Šumavě."
>
  <Header />

  <main>
    <section style="min-height: 70vh; display: flex; align-items: center; padding: 80px 24px; background: #1a1a1a;">
      <div style="max-width: 1200px; margin: 0 auto; width: 100%;">
        <p style="font-size: 14px; letter-spacing: .2em; text-transform: uppercase; color: rgba(255,255,255,.7);">
          Borová Lada · Šumava
        </p>
        <h1 style="font-size: 56px; line-height: 1.05; margin: 16px 0; font-weight: 800;">
          Apartmány Černý vlk
        </h1>
        <p style="max-width: 720px; font-size: 20px; color: rgba(255,255,255,.8);">
          Moderní horské ubytování v srdci Národního parku Šumava.
        </p>

        <div style="margin-top: 32px; display: flex; flex-wrap: wrap; gap: 16px;">
          <a
            href="/apartmany/cerveny"
            style="display: inline-block; padding: 14px 20px; background: #ffffff; color: #111111; font-weight: 700;"
          >
            Zobrazit apartmán Červený
          </a>

          <a
            href="/vybaveni"
            style="display: inline-block; padding: 14px 20px; border: 1px solid rgba(255,255,255,.2); color: #ffffff;"
          >
            Zobrazit vybavení
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
