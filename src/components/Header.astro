---
import { getRelativeLocaleUrl } from 'astro:i18n';

const { currentSection = '' } = Astro.props;

const messages = {
  cs: {
    'nav.home': 'Úvodní stránka',
    'nav.apartments': 'Apartmány',
    'nav.location': 'Okolí',
    'nav.reviews': 'Recenze',
    'nav.book': 'Rezervovat',
    'nav.theme': 'Přepnout světlý/tmavý režim',
    'nav.menu': 'Otevřít menu',
    'nav.lang.cs': 'CS',
    'nav.lang.de': 'DE',
    'nav.lang.en': 'EN',
    'brand.name': 'Černý vlk',
  },
  de: {
    'nav.home': 'Startseite',
    'nav.apartments': 'Apartments',
    'nav.location': 'Umgebung',
    'nav.reviews': 'Bewertungen',
    'nav.book': 'Buchen',
    'nav.theme': 'Hell/Dunkel umschalten',
    'nav.menu': 'Menü öffnen',
    'nav.lang.cs': 'CS',
    'nav.lang.de': 'DE',
    'nav.lang.en': 'EN',
    'brand.name': 'Černý vlk',
  },
  en: {
    'nav.home': 'Homepage',
    'nav.apartments': 'Apartments',
    'nav.location': 'Location',
    'nav.reviews': 'Reviews',
    'nav.book': 'Book now',
    'nav.theme': 'Toggle light/dark mode',
    'nav.menu': 'Open menu',
    'nav.lang.cs': 'CS',
    'nav.lang.de': 'DE',
    'nav.lang.en': 'EN',
    'brand.name': 'Černý vlk',
  },
} as const;

type Lang = keyof typeof messages;
type MessageKey = keyof typeof messages.cs;

const rawLocale = Astro.currentLocale ?? 'cs';
const lang: Lang = rawLocale === 'de' || rawLocale === 'en' ? rawLocale : 'cs';

const t = (key: MessageKey) => messages[lang][key] ?? messages.cs[key];

const homeUrl = getRelativeLocaleUrl(lang, '/');
const switchCs = getRelativeLocaleUrl('cs', '/');
const switchDe = getRelativeLocaleUrl('de', '/');
const switchEn = getRelativeLocaleUrl('en', '/');
---

<nav id="main-nav">
  <a href={homeUrl} class="nav-logo" aria-label={`Apartmány Černý vlk – ${t('nav.home')}`}>
    <svg
      viewBox="0 0 1746 2012"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m2109.87 544-550.872 459.931" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2095 551h280.28" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2364 553.628 2768.353 368" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2752 388v248.245" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2563 798.706 2759.458 619" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2580 792h226.89" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2785 944.502V782" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m2456 1286.18 333.721-357.182" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m2463.58 1268-7.578 1062.06" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2472.22 2308h-415.221" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m2081 2296.78 11.463-306.782" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1565.78 1000-248.776 113.036" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1338 1113 219.92 106.38" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M1119 2254.95 1565.532 1195" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1093 2267 446.53 45.92" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1518 2330.39 134.924-400.392" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M1627 1946h481.14" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="M2092 1966.46v-399.459" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1963 1549 148.62 41.86" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1978.4 1570-8.397 210.472" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1650 1886.9 201.655-332.897" transform="translate(-1086 -343)" />
      <path fill="none" stroke-miterlimit="8" stroke-width="45.833" stroke="currentColor" d="m1850 1580 118.61 187.87" transform="translate(-1086 -343)" />
    </svg>
    <span class="nav-logo-text">{t('brand.name')}</span>
  </a>

  <div class="nav-links">
    <a href={`${homeUrl}#apartmany`} aria-current={currentSection === 'apartmany' ? 'page' : undefined}>
      {t('nav.apartments')}
    </a>
    <a href={`${homeUrl}#okoli`} aria-current={currentSection === 'okoli' ? 'page' : undefined}>
      {t('nav.location')}
    </a>
    <a href={`${homeUrl}#recenze`} aria-current={currentSection === 'recenze' ? 'page' : undefined}>
      {t('nav.reviews')}
    </a>

    <div class="nav-lang" aria-label="Language switcher">
      <a href={switchCs} class:list={[lang === 'cs' && 'is-active']}>{t('nav.lang.cs')}</a>
      <a href={switchDe} class:list={[lang === 'de' && 'is-active']}>{t('nav.lang.de')}</a>
      <a href={switchEn} class:list={[lang === 'en' && 'is-active']}>{t('nav.lang.en')}</a>
    </div>

    <a href={`${homeUrl}#rezervace`} class="nav-cta">{t('nav.book')}</a>

    <button
      class="nav-theme"
      data-theme-toggle
      type="button"
      aria-label={t('nav.theme')}
      title={t('nav.theme')}
    >
      <span class="theme-icon theme-icon-sun" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
      </span>
      <span class="theme-icon theme-icon-moon" aria-hidden="true" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </span>
    </button>
  </div>

  <div
    class="nav-hamburger"
    id="hamburger"
    aria-label={t('nav.menu')}
    role="button"
    tabindex="0"
  >
    <span></span><span></span><span></span>
  </div>

  <script>
    (() => {
      const initThemeToggle = () => {
        const button = document.querySelector('[data-theme-toggle]');
        if (!button) return;

        const sun = button.querySelector('.theme-icon-sun');
        const moon = button.querySelector('.theme-icon-moon');
        const root = document.documentElement;

        const syncIcon = (theme) => {
          const isDark = theme === 'dark';
          if (sun) sun.hidden = isDark;
          if (moon) moon.hidden = !isDark;
        };

        const currentTheme = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        syncIcon(currentTheme);

        if (button.dataset.bound === 'true') return;
        button.dataset.bound = 'true';

        button.addEventListener('click', () => {
          const nextTheme = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', nextTheme);
          localStorage.setItem('theme', nextTheme);
          syncIcon(nextTheme);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initThemeToggle, { once: true });
      } else {
        initThemeToggle();
      }
    })();
  </script>
</nav>
