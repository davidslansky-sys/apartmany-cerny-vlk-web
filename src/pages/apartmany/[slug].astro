---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const apartments = await getCollection('apartments', ({ data }) => data.lang === 'cs');

  return apartments.map((apartment) => ({
    params: { slug: apartment.data.slug },
    props: { apartment },
  }));
}

const { apartment } = Astro.props;
const { Content } = await render(apartment);
const { data } = apartment;
---

<BaseLayout title={data.seo.title} description={data.seo.description}>
  <Header />

  <main id="obsah">
    {/* Hero sekce */}
    <section class="page-section" style="border-bottom: 1px solid rgba(255,255,255,.12);">
      <div class="page-inner">
        <p style="font-size: 14px; letter-spacing: .18em; text-transform: uppercase; color: rgba(255,255,255,.7);">
          Apartmán · Borová Lada
        </p>
        <h1 style="font-size: 48px; line-height: 1.05; margin: 12px 0 20px; font-weight: 800;">
          {data.title}
        </h1>
        <p style="max-width: 720px; font-size: 20px; color: rgba(255,255,255,.8);">
          {data.summary}
        </p>
      </div>
    </section>

    {/* Parametry apartmánu */}
    <section class="page-section">
      <div class="page-inner">
        <div class="info-grid">
          <div class="info-card">
            <p class="info-card-label">Kapacita</p>
            <strong>{data.capacityText}</strong>
          </div>
          <div class="info-card">
            <p class="info-card-label">Velikost</p>
            <strong>{data.sizeM2} m²</strong>
          </div>
          <div class="info-card">
            <p class="info-card-label">Číslo objektu</p>
            <strong>{data.houseNumber ?? 'Bude doplněno'}</strong>
          </div>
        </div>
      </div>
    </section>

    {/* Hlavní výhody */}
    <section class="page-section">
      <div class="page-inner">
        <h2 class="section-title">Hlavní výhody</h2>
        <ul style="padding-left: 20px; line-height: 1.8;">
          {data.highlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    {/* Vybavení */}
    <section class="page-section">
      <div class="page-inner">
        <h2 class="section-title">Vybavení</h2>
        <ul style="padding-left: 20px; line-height: 1.8;">
          {data.amenities.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    {/* Popis apartmánu */}
    <section class="page-section">
      <div class="page-inner">
        <h2 class="section-title">Popis apartmánu</h2>
        <div class="section-text">
          <Content />
        </div>
      </div>
    </section>

    {/* Galerie */}
    <section class="page-section">
      <div class="page-inner">
        <h2 class="section-title">Galerie</h2>
        <div class="gallery-grid">
          {data.gallery.map((image) => (
            <img
              src={image}
              alt={data.title}
              loading="lazy"
              class="gallery-img"
            />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
