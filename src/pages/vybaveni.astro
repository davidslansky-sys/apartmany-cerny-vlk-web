---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Vybavení | Apartmány Černý vlk"
  description="Přehled vybavení a zázemí objektu Apartmány Černý vlk."
>
  <Header />

  <main>
    <section style="padding: 72px 24px; border-bottom: 1px solid rgba(255,255,255,.12);">
      <div style="max-width: 1200px; margin: 0 auto;">
        <p style="font-size: 14px; letter-spacing: .18em; text-transform: uppercase; color: rgba(255,255,255,.7);">
          Vybavení a zázemí
        </p>
        <h1 style="font-size: 48px; line-height: 1.05; margin: 12px 0 20px; font-weight: 800;">
          Vybavení objektu
        </h1>
        <p style="max-width: 760px; font-size: 20px; color: rgba(255,255,255,.8);">
          Tato stránka je zatím připravena jako dočasná Astro verze. V dalším kroku sem převedeme obsah z původního HTML prototypu.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
