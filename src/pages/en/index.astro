---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PrevioWidget from '../../components/PrevioWidget.astro';
---

<BaseLayout
  lang="en"
  title="Apartmány Černý vlk – Borová Lada, Šumava"
  description="5 apartments in the quiet center of Šumava. Borová Lada – nature, comfort and the whole national park within easy reach."
>
  <Header />

  <section class="hero" id="uvod">
    <div
      class="hero-bg"
      style="background-image:url('/images/hero/hero-borova-lada.jpeg');"
    ></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Borová Lada · Šumava</p>
      <h1>
        In the quiet center of Šumava.
        <em>Yet with every essential convenience.</em>
      </h1>
      <p class="hero-perex">
        Borová Lada lies in the heart of the national park. Forests, cycling paths and cross-country trails begin almost right outside the village.
        At the same time, you have restaurants, a café, a shop, sports facilities and a playground within walking distance.
      </p>
      <div class="hero-actions">
        <a href="#rezervace" class="btn-primary">Check availability</a>
        <a href="#apartmany" class="btn-ghost">View apartments</a>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">Scroll</div>
  </section>

  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat"><span><strong>5 apartments</strong> · 2 houses</span></div>
      <div class="stat"><span><strong>4–8 guests</strong> / apartment</span></div>
      <div class="stat"><span>Total capacity <strong>28 guests</strong></span></div>
      <div class="stat"><span>Rating <strong>9.4/10</strong></span></div>
    </div>
  </div>

  <section id="apartmany">
    <div class="section-inner">
      <p class="section-label reveal">Accommodation</p>
      <h2 class="section-title reveal reveal-delay-1">Five apartments. <em>One character.</em></h2>
      <p class="section-lead reveal reveal-delay-2">
        Each apartment has its own personality – name, color and orientation. All of them share the same attention to detail and comfort.
      </p>

      <div class="apt-grid">
        <div class="apt-row-label">House No. 116</div>

        <div class="apt-card-big reveal">
          <div class="apt-photo">
            <img src="/images/apartmany/cerveny/cerveny-01.jpeg" alt="Red apartment – main interior" width="800" height="500" loading="lazy" />
          </div>
          <div class="apt-info">
            <div class="apt-name-row">
              <span class="apt-color-dot" style="background:#c0392b"></span>
              <h3 class="apt-name">Red</h3>
            </div>
            <div class="apt-meta">
              <span class="apt-meta-item">8 guests</span>
              <span class="apt-meta-item">3 bedrooms</span>
              <span class="apt-meta-item">116 m²</span>
              <span class="apt-meta-item">No. 116</span>
            </div>
            <p class="apt-desc">
              Our largest apartment with a generous shared living space across the whole ground floor. Great for larger families or groups of friends.
            </p>
            <a href="/en/" class="apt-link">Apartment detail</a>
          </div>
        </div>

        <div class="apt-row">
          <div class="apt-card-sm reveal">
            <div class="apt-photo">
              <img src="/images/apartmany/zluty/zluty-01.jpg" alt="Yellow apartment – main interior" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#d4a017"></span>
                <h3 class="apt-name">Yellow</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 guests</span>
                <span class="apt-meta-item">2 bedrooms</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">A bright apartment with afternoon and evening sun. Practical layout for families and longer stays.</p>
              <a href="/en/" class="apt-link">Apartment detail</a>
            </div>
          </div>

          <div class="apt-card-sm reveal reveal-delay-1">
            <div class="apt-photo">
              <img src="/images/apartmany/zeleny/zeleny-01.jpg" alt="Green apartment – main interior" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#2e7d32"></span>
                <h3 class="apt-name">Green</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 guests</span>
                <span class="apt-meta-item">2 bedrooms</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">An apartment with morning sun and a calm atmosphere. Ideal for guests who want to head outdoors right after breakfast.</p>
              <a href="/en/" class="apt-link">Apartment detail</a>
            </div>
          </div>
        </div>

        <div class="apt-row-label">House No. 117</div>

        <div class="apt-row">
          <div class="apt-card-sm reveal">
            <div class="apt-photo">
              <img src="/images/apartmany/modry/modry-01.jpeg" alt="Blue apartment – main interior" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#1565c0"></span>
                <h3 class="apt-name">Blue</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 guests</span>
                <span class="apt-meta-item">2 bedrooms</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">A comfortable apartment with morning sun, ideal for relaxed longer stays in every season.</p>
              <a href="/en/" class="apt-link">Apartment detail</a>
            </div>
          </div>

          <div class="apt-card-sm reveal reveal-delay-1">
            <div class="apt-photo">
              <img src="/images/apartmany/sedy/sedy-01.jpeg" alt="Grey apartment – main interior" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#607d8b"></span>
                <h3 class="apt-name">Grey</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 guests</span>
                <span class="apt-meta-item">2 bedrooms</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">A quiet apartment with afternoon sun. The same comfort and layout as Blue, suitable for couples and families.</p>
              <a href="/en/" class="apt-link">Apartment detail</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="okoli">
    <div class="section-inner">
      <div class="okoli-layout">
        <div class="okoli-text">
          <p class="section-label reveal">Location</p>
          <h2 class="section-title reveal reveal-delay-1">Šumava at your doorstep. <em>In every season.</em></h2>
          <p class="reveal reveal-delay-2">Cycling paths and cross-country ski trails start almost right outside the village. Borová Lada is a perfect base for trips around the Czech and Bavarian Šumava region.</p>
          <p class="reveal">In summer you can enjoy forest paths, peat bogs, viewpoints and natural swimming spots. In winter, ski trails and downhill areas are within easy reach.</p>
          <p class="reveal">At the same time, you stay in a peaceful place with clean air and all essentials nearby.</p>
        </div>

        <div class="okoli-photos reveal">
          <img src="/images/domy/dum-116/dum-116-02.jpeg" alt="House No. 116 in Borová Lada" width="800" height="280" loading="lazy" />
          <img src="/images/domy/dum-117/dum-117-01.jpg" alt="House No. 117 in Borová Lada" width="400" height="200" loading="lazy" />
          <img src="/images/domy/dum-116/dum-116-07.jpg" alt="Borová Lada and surroundings" width="400" height="200" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="recenze">
    <div class="section-inner">
      <div class="recenze-header">
        <div>
          <p class="section-label reveal">Guest reviews</p>
          <h2 class="section-title reveal reveal-delay-1">What our <em>guests say</em></h2>
        </div>
        <div class="recenze-score reveal">
          <div class="score-big">9.4</div>
          <div class="score-sub">out of 10 · 300+ reviews</div>
          <div class="score-sources">
            <span class="score-src">Booking.com 9.3</span>
            <span class="score-src">Google 4.9★</span>
            <span class="score-src">Mapy.cz 5.0★</span>
            <span class="score-src">Guest reviews 9.7</span>
          </div>
        </div>
      </div>

      <div class="reviews-grid">
        <div class="review-card reveal">
          <p class="review-quote">Very well designed and fully equipped — we really didn’t miss anything during our stay.</p>
          <div class="review-author"><strong>Jindřiška</strong> · April 2025</div>
        </div>
        <div class="review-card reveal reveal-delay-1">
          <p class="review-quote">Beautiful location, stylish apartments, directly connected to the surrounding green areas.</p>
          <div class="review-author"><strong>Hunor</strong> · Germany · Booking.com</div>
        </div>
        <div class="review-card reveal reveal-delay-2">
          <p class="review-quote">The apartments are new and cozy. We really enjoyed our holiday and would love to come back.</p>
          <div class="review-author"><strong>Tomáš</strong> · Google</div>
        </div>
      </div>
    </div>
  </section>

  <section id="rezervace">
    <div class="section-inner">
      <div class="rezervace-layout">
        <div class="rezervace-info">
          <p class="section-label reveal">Booking</p>
          <h2 class="section-title reveal reveal-delay-1">Availability <em>and reservation</em></h2>
          <p class="reveal reveal-delay-2">Check availability directly online. Reservations are confirmed instantly.</p>

          <div class="contact-line reveal">
            <div class="contact-item"><span>📞</span><a href="tel:+420728739288">+420 728 739 288</a></div>
            <div class="contact-item"><span>📞</span><a href="tel:+420739753580">+420 739 753 580</a></div>
            <div class="contact-item"><span>✉️</span><a href="mailto:recepce@apartmanycernyvlk.cz">recepce@apartmanycernyvlk.cz</a></div>
          </div>
        </div>

        <div class="reveal">
          <PrevioWidget lang="en" />
        </div>
      </div>
    </div>
  </section>

  <Footer lang="en" />
</BaseLayout>
