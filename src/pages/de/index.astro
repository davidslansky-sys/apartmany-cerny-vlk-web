---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PrevioWidget from '../../components/PrevioWidget.astro';
---

<BaseLayout
  lang="de"
  title="Apartmány Černý vlk – Borová Lada, Böhmerwald"
  description="5 Apartments im ruhigen Zentrum des Böhmerwalds. Borová Lada – Natur, Komfort und der ganze Šumava-Nationalpark in Reichweite."
>
  <Header />

  <section class="hero" id="uvod">
    <div
      class="hero-bg"
      style="background-image:url('/images/hero/hero-borova-lada.jpeg');"
    ></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Borová Lada · Böhmerwald</p>
      <h1>
        Im ruhigen Zentrum des Böhmerwalds.
        <em>Und dennoch mit kompletter Infrastruktur.</em>
      </h1>
      <p class="hero-perex">
        Borová Lada liegt im Herzen des Nationalparks. Wälder, Radwege und Langlaufloipen beginnen praktisch direkt im Ort.
        Gleichzeitig finden Sie hier Restaurants, Café, Geschäft, Sportanlagen und einen Spielplatz – alles bequem zu Fuß erreichbar.
      </p>
      <div class="hero-actions">
        <a href="#rezervace" class="btn-primary">Verfügbarkeit prüfen</a>
        <a href="#apartmany" class="btn-ghost">Apartments ansehen</a>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">Scroll</div>
  </section>

  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat"><span><strong>5 Apartments</strong> · 2 Häuser</span></div>
      <div class="stat"><span><strong>4–8 Personen</strong> / Apartment</span></div>
      <div class="stat"><span>Gesamtkapazität <strong>28 Personen</strong></span></div>
      <div class="stat"><span>Bewertung <strong>9.4/10</strong></span></div>
    </div>
  </div>

  <section id="apartmany">
    <div class="section-inner">
      <p class="section-label reveal">Unterkunft</p>
      <h2 class="section-title reveal reveal-delay-1">Fünf Apartments. <em>Ein Charakter.</em></h2>
      <p class="section-lead reveal reveal-delay-2">
        Jedes Apartment hat seine eigene Persönlichkeit – Name, Farbe und Ausrichtung. Alle verbindet dieselbe Liebe zum Detail und ein hoher Standard.
      </p>

      <div class="apt-grid">
        <div class="apt-row-label">Haus Nr. 116</div>

        <div class="apt-card-big reveal">
          <div class="apt-photo">
            <img src="/images/apartmany/cerveny/cerveny-01.jpeg" alt="Apartment Rotes – Hauptinnenraum" width="800" height="500" loading="lazy" />
          </div>
          <div class="apt-info">
            <div class="apt-name-row">
              <span class="apt-color-dot" style="background:#c0392b"></span>
              <h3 class="apt-name">Rotes</h3>
            </div>
            <div class="apt-meta">
              <span class="apt-meta-item">8 Personen</span>
              <span class="apt-meta-item">3 Schlafzimmer</span>
              <span class="apt-meta-item">116 m²</span>
              <span class="apt-meta-item">Nr. 116</span>
            </div>
            <p class="apt-desc">
              Das größte Apartment mit großzügigem Gemeinschaftsraum über das gesamte Erdgeschoss. Ideal für größere Familien oder Freundesgruppen.
            </p>
            <a href="/de/" class="apt-link">Apartment-Detail</a>
          </div>
        </div>

        <div class="apt-row">
          <div class="apt-card-sm reveal">
            <div class="apt-photo">
              <img src="/images/apartmany/zluty/zluty-01.jpg" alt="Apartment Gelbes – Hauptinnenraum" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#d4a017"></span>
                <h3 class="apt-name">Gelbes</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 Personen</span>
                <span class="apt-meta-item">2 Schlafzimmer</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">Helles Apartment mit Nachmittags- und Abendsonne. Praktisch für Familien und längere Aufenthalte.</p>
              <a href="/de/" class="apt-link">Apartment-Detail</a>
            </div>
          </div>

          <div class="apt-card-sm reveal reveal-delay-1">
            <div class="apt-photo">
              <img src="/images/apartmany/zeleny/zeleny-01.jpg" alt="Apartment Grünes – Hauptinnenraum" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#2e7d32"></span>
                <h3 class="apt-name">Grünes</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 Personen</span>
                <span class="apt-meta-item">2 Schlafzimmer</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">Apartment mit Morgensonne und ruhiger Atmosphäre. Perfekt für Gäste, die früh in die Natur starten möchten.</p>
              <a href="/de/" class="apt-link">Apartment-Detail</a>
            </div>
          </div>
        </div>

        <div class="apt-row-label">Haus Nr. 117</div>

        <div class="apt-row">
          <div class="apt-card-sm reveal">
            <div class="apt-photo">
              <img src="/images/apartmany/modry/modry-01.jpeg" alt="Apartment Blaues – Hauptinnenraum" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#1565c0"></span>
                <h3 class="apt-name">Blaues</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 Personen</span>
                <span class="apt-meta-item">2 Schlafzimmer</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">Komfortables Apartment mit Morgensonne für entspannte Aufenthalte zu jeder Jahreszeit.</p>
              <a href="/de/" class="apt-link">Apartment-Detail</a>
            </div>
          </div>

          <div class="apt-card-sm reveal reveal-delay-1">
            <div class="apt-photo">
              <img src="/images/apartmany/sedy/sedy-01.jpeg" alt="Apartment Graues – Hauptinnenraum" width="600" height="300" loading="lazy" />
            </div>
            <div class="apt-info">
              <div class="apt-name-row">
                <span class="apt-color-dot" style="background:#607d8b"></span>
                <h3 class="apt-name">Graues</h3>
              </div>
              <div class="apt-meta">
                <span class="apt-meta-item">4+1 Personen</span>
                <span class="apt-meta-item">2 Schlafzimmer</span>
                <span class="apt-meta-item">56 m²</span>
              </div>
              <p class="apt-desc">Ruhiges Apartment mit Nachmittagssonne. Ideal für Paare und Familien.</p>
              <a href="/de/" class="apt-link">Apartment-Detail</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="okoli">
    <div class="section-inner">
      <div class="okoli-layout">
        <div class="okoli-text">
          <p class="section-label reveal">Lage</p>
          <h2 class="section-title reveal reveal-delay-1">Der Böhmerwald vor der Tür. <em>Zu jeder Jahreszeit.</em></h2>
          <p class="reveal reveal-delay-2">Radwege und Langlaufloipen beginnen praktisch direkt hinter dem Dorf. Borová Lada ist ein perfekter Ausgangspunkt für Ausflüge.</p>
          <p class="reveal">Im Sommer erwarten Sie Waldwege, Hochmoore, Ausblicke und Naturbäder. Im Winter erreichen Sie Loipen und Skigebiete auf tschechischer und deutscher Seite.</p>
          <p class="reveal">Gleichzeitig wohnen Sie an einem ruhigen Ort mit sauberer Luft und guter Erreichbarkeit.</p>
        </div>

        <div class="okoli-photos reveal">
          <img src="/images/domy/dum-116/dum-116-02.jpeg" alt="Haus Nr. 116 in Borová Lada" width="800" height="280" loading="lazy" />
          <img src="/images/domy/dum-117/dum-117-01.jpg" alt="Haus Nr. 117 in Borová Lada" width="400" height="200" loading="lazy" />
          <img src="/images/domy/dum-116/dum-116-07.jpg" alt="Umgebung von Borová Lada" width="400" height="200" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="recenze">
    <div class="section-inner">
      <div class="recenze-header">
        <div>
          <p class="section-label reveal">Gästestimmen</p>
          <h2 class="section-title reveal reveal-delay-1">Was unsere <em>Gäste schreiben</em></h2>
        </div>
        <div class="recenze-score reveal">
          <div class="score-big">9.4</div>
          <div class="score-sub">von 10 · über 300 Bewertungen</div>
          <div class="score-sources">
            <span class="score-src">Booking.com 9.3</span>
            <span class="score-src">Google 4.9★</span>
            <span class="score-src">Mapy.cz 5.0★</span>
            <span class="score-src">Gästebewertungen 9.7</span>
          </div>
        </div>
      </div>

      <div class="reviews-grid">
        <div class="review-card reveal">
          <p class="review-quote">Sehr gut durchdacht, hervorragend ausgestattet – es fehlte uns wirklich an nichts.</p>
          <div class="review-author"><strong>Jindřiška</strong> · April 2025</div>
        </div>
        <div class="review-card reveal reveal-delay-1">
          <p class="review-quote">Beautiful location, stylish apartments, directly connected to the surrounding green areas.</p>
          <div class="review-author"><strong>Hunor</strong> · Deutschland · Booking.com</div>
        </div>
        <div class="review-card reveal reveal-delay-2">
          <p class="review-quote">Neue, gemütlich eingerichtete Apartments. Wir haben den Aufenthalt sehr genossen.</p>
          <div class="review-author"><strong>Tomáš</strong> · Google</div>
        </div>
      </div>
    </div>
  </section>

  <section id="rezervace">
    <div class="section-inner">
      <div class="rezervace-layout">
        <div class="rezervace-info">
          <p class="section-label reveal">Reservierung</p>
          <h2 class="section-title reveal reveal-delay-1">Freie Termine <em>und Buchung</em></h2>
          <p class="reveal reveal-delay-2">Prüfen Sie die Verfügbarkeit direkt online. Die Reservierung wird sofort bestätigt.</p>

          <div class="contact-line reveal">
            <div class="contact-item"><span>📞</span><a href="tel:+420728739288">+420 728 739 288</a></div>
            <div class="contact-item"><span>📞</span><a href="tel:+420739753580">+420 739 753 580</a></div>
            <div class="contact-item"><span>✉️</span><a href="mailto:recepce@apartmanycernyvlk.cz">recepce@apartmanycernyvlk.cz</a></div>
          </div>
        </div>

        <div class="reveal">
          <PrevioWidget lang="de" />
        </div>
      </div>
    </div>
  </section>

  <Footer lang="de" />
</BaseLayout>
